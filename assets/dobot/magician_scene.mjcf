<mujoco model="magician">
  <compiler angle="radian"/>

  <option integrator="implicitfast" iterations="50"/>

  <asset>
    <mesh name="magicianBase" file="meshes/visual/magicianBase.obj"/>
    <mesh name="magicianLink1" file="meshes/visual/magicianLink1.obj"/>
    <mesh name="magicianLink2" file="meshes/visual/magicianLink2.obj"/>
    <mesh name="magicianLink3" file="meshes/visual/magicianLink3.obj"/>
    <mesh name="magicianLink4" file="meshes/visual/magicianLink4.obj"/>
    <mesh name="gripper_core" file="meshes/visual/gripper_core.obj"/>
    <mesh name="jaw_left" file="meshes/visual/jaw_left.obj"/>
    <mesh name="jaw_right" file="meshes/visual/jaw_right.obj"/>
  </asset>

  <worldbody>
    <geom name="floor" size="1 1 0.1" pos="0 0 -0.131" type="plane" conaffinity="2" rgba="0.7 0.7 0.7 1"/>
    <geom type="mesh" contype="2" mesh="magicianBase"/>
    <light pos="0 0 2" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="1 1 2" dir="-0.408248 -0.408248 -0.816497" diffuse="0.4 0.4 0.4"/>
    <body name="magician_link_1">
      <joint name="magician_joint_1" pos="0 0 0" axis="0 0 1" range="-2.18166 2.18166" actuatorfrcrange="-2000 2000"/>
      <geom type="mesh" contype="2" mesh="magicianLink1"/>
      <body name="magician_link_2">
        <joint name="magician_joint_2" pos="0 0 0" axis="0 1 0" range="-0.0872665 1.5708" actuatorfrcrange="-2000 2000"/>
        <geom quat="0.984808 0 -0.173648 0" type="mesh" contype="2" mesh="magicianLink2"/>
        <body name="magician_link_3" pos="0 0 0.135">
          <joint name="magician_joint_3" pos="0 0 0" axis="0 1 0" range="-0.261799 1.22173" actuatorfrcrange="-2000 2000"/>
          <geom pos="0.0164524 0 -0.133994" quat="0.97237 0 -0.233445 0" type="mesh" contype="2" mesh="magicianLink3"/>
          <body name="magician_link_virtual" pos="0.147 0 0">
            <inertial pos="0 0 0" mass="0.001" diaginertia="1e-06 1e-06 1e-06"/>
            <joint name="magician_joint_mimic_1" pos="0 0 0" axis="0 1 0" limited="true" range="-1.5708 0.0873" actuatorfrcrange="-2000 2000"/>
            <body name="magician_link_4">
              <joint name="magician_joint_mimic_2" pos="0 0 0" axis="0 1 0" limited="true" range="-1.2217 0.2618" actuatorfrcrange="-2000 2000"/>
              <geom pos="-0.177151 0 -0.0585951" quat="1 0 0 0" type="mesh" contype="2" mesh="magicianLink4"/>
              <body name="magician_link_gripper_core" pos="0.06 0 0">
                <joint name="magician_joint_4" pos="0 0 0" axis="0 0 1" range="-2.61799 2.61799" actuatorfrcrange="-2000 2000"/>
                <geom pos="-8.06784e-05 0 -0.0278434" type="mesh" contype="2" mesh="gripper_core"/>
                <site name="mic0" pos="0 0 0"/>
                <site name="mic1" pos="0.004 0 0"/>
                <site name="mic2" pos="0.012 0 0"/>
                <site name="mic3" pos="0.028 0 0"/>
                <site name="mic4" pos="0 0.012 0"/>
                <site name="mic5" pos="0 -0.012 0"/>
                <body name="magician_link_gripper_jaw_left">
                  <joint name="magician_joint_prismatic_l" pos="0 0 0" axis="0 1 0" type="slide" range="0 0.0135" actuatorfrcrange="-2000 2000"/>
                  <geom pos="-8.06784e-05 -0.0009 -0.0278434" quat="1 0 0 0" type="mesh" contype="2" mesh="jaw_left"/>
                </body>
                <body name="magician_link_gripper_jaw_right">
                  <joint name="magician_joint_prismatic_r" pos="0 0 0" axis="0 1 0" type="slide" limited="true" range="-0.0135 0" actuatorfrcrange="-2000 2000"/>
                  <geom pos="-8.06784e-05 0.0009 -0.0278434" quat="1 0 0 0" type="mesh" contype="2" mesh="jaw_right"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
    <body name="test_block" pos="0.2 0 -0.126">
      <joint name="test_block_freejoint" type="free"/>
      <geom name="test_block_geom" size="0.005 0.005 0.005" type="box" conaffinity="3" mass="0.05" rgba="0.9 0.3 0.3 1"/>
    </body>
    <body name="target_zone" pos="5 5 -0.131" mocap="true">
      <inertial pos="0 0 0" mass="0.00565487" diaginertia="1.27423e-06 1.27423e-06 2.54469e-06"/>
    </body>
  </worldbody>

  <equality>
    <joint name="parallel_link_1" joint1="magician_joint_mimic_1" joint2="magician_joint_2" polycoef="0 -1 0 0 0" solref="0.001" solimp="0.99 0.999"/>
    <joint name="parallel_link_2" joint1="magician_joint_mimic_2" joint2="magician_joint_3" polycoef="0 -1 0 0 0" solref="0.001" solimp="0.99 0.999"/>
    <joint name="gripper_sync" joint1="magician_joint_prismatic_r" joint2="magician_joint_prismatic_l" polycoef="0 -1 0 0 0" solref="0.001" solimp="0.99 0.999"/>
    <weld name="block_weld" body1="test_block" anchor="0 1 0" relpose="0 0 0 1 0 0 0" torquescale="1" active="false"/>
  </equality>

  <actuator>
    <general name="act_joint_1" joint="magician_joint_1" ctrllimited="true" ctrlrange="-2.0944 2.0944" biastype="affine" gainprm="300" biasprm="0 -300 -60"/>
    <general name="act_joint_2" joint="magician_joint_2" ctrllimited="true" ctrlrange="0 1.4835" biastype="affine" gainprm="50" biasprm="0 -50 -10"/>
    <general name="act_joint_3" joint="magician_joint_3" ctrllimited="true" ctrlrange="-0.2618 1.2217" biastype="affine" gainprm="50" biasprm="0 -50 -10"/>
    <general name="act_joint_4" joint="magician_joint_4" ctrllimited="true" ctrlrange="-1.5708 1.5708" biastype="affine" gainprm="20" biasprm="0 -20 -4"/>
    <general name="act_gripper" joint="magician_joint_prismatic_l" ctrllimited="true" ctrlrange="0 0.0135" biastype="affine" gainprm="100" biasprm="0 -100 -20"/>
  </actuator>
</mujoco>
